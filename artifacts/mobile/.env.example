# Base URL of the NeuroFit backend API. The app prepends this to all
# requests. Must include scheme + host (no trailing slash, no /api).
#
# Local laptop: http://localhost:8080
# Replit dev:   https://<repl-id>-<port>.<replit-domain> (Replit auto-injects $REPLIT_DEV_DOMAIN at runtime)
# Staging/prod: https://api.neurofit.example
EXPO_PUBLIC_API_URL=http://localhost:8080

# Google AdMob rewarded ad units (FR-7.x). Leave blank in development —
# the app falls back to Google's official test ad units when __DEV__ is
# true. Populate these for production builds with the unit IDs from your
# AdMob console. Both platforms only show REWARDED ads (no interstitial,
# banner, or native).
EXPO_PUBLIC_ADMOB_ANDROID_REWARDED_UNIT=
EXPO_PUBLIC_ADMOB_IOS_REWARDED_UNIT=
