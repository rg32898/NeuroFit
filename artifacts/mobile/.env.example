# Base URL of the NeuroFit backend API. The app prepends this to all
# requests. Must include scheme + host (no trailing slash, no /api).
#
# Local laptop: http://localhost:8080
# Replit dev:   https://<repl-id>-<port>.<replit-domain> (Replit auto-injects $REPLIT_DEV_DOMAIN at runtime)
# Staging/prod: https://api.neurofit.example
EXPO_PUBLIC_API_URL=http://localhost:8080
