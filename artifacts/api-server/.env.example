PORT=8080
NODE_ENV=development
LOG_LEVEL=info
CORS_ORIGIN=http://localhost:3000
DATABASE_URL="postgresql://user:pass@localhost:5432/neurofit?schema=public"

# JWT — generate strong secrets: openssl rand -base64 48
JWT_ACCESS_SECRET=replace_me_with_long_random_string
JWT_REFRESH_SECRET=replace_me_with_another_long_random_string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# Apple Sign-In (optional)
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# Google Sign-In (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Cron + support tooling secrets — generate with: openssl rand -hex 32
# CRON_SECRET protects POST /api/admin/cron/daily and /api/admin/cron/billing
# so any external scheduler (Render cron, Fly machines, GitHub Actions,
# cron-job.org, plain crontab, etc.) can call them.
# SUPPORT_TOKEN protects POST /api/progress/restore-streak for support agents.
CRON_SECRET=replace_me
SUPPORT_TOKEN=replace_me

# ── Billing (FR-6.x) ─────────────────────────────────────────────────────────
# Stripe — keys come from https://dashboard.stripe.com/apikeys
# STRIPE_WEBHOOK_SECRET is the per-endpoint signing secret shown when you
# create the webhook endpoint in the Stripe dashboard.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Apple — App-specific shared secret from App Store Connect → My Apps → App
# Information → App-Specific Shared Secret. Used to call /verifyReceipt.
APPLE_SHARED_SECRET=

# Google Play — either an absolute path to a service account JSON file OR a
# base64-encoded copy of the same JSON (so it fits inside an env var).
# Service account needs the "View financial data" permission on the app in
# Google Play Console + the Android Publisher API enabled in GCP.
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON=
GOOGLE_PLAY_PACKAGE_NAME=

# Trial length and the FR-6.3 "trial about to end" reminder window.
SUBSCRIPTION_TRIAL_DAYS=7
SUBSCRIPTION_REMINDER_HOURS=48

# ── Notifications (Prompt 10) ────────────────────────────────────────────────
# Email transport. Resend wins if both are set. Leave both blank in dev — the
# server logs notification attempts to stdout instead of sending.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
RESEND_API_KEY=

# Expo Push (used for both iOS and Android notifications via expo-server-sdk
# wire format). Leave blank in dev — sendPush() logs to stdout instead.
EXPO_ACCESS_TOKEN=

# Sender address for outbound transactional email.
FROM_EMAIL=hello@neurofit.example
