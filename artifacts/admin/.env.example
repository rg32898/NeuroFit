# Backend API base URL — same /api server the mobile app uses.
# In Replit dev this is the proxied URL; in self-hosted it points at the
# api-server deployment.
NEXT_PUBLIC_API_URL=http://localhost:80

# Internal URL the admin's BFF route uses server-side. Falls back to
# NEXT_PUBLIC_API_URL when unset. Useful in containerised deploys where the
# admin and api-server share a Docker network.
ADMIN_API_INTERNAL_URL=http://localhost:80

# Cookie security (set true in production over HTTPS).
COOKIE_SECURE=false
