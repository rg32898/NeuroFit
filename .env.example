# =============================================================================
# NeuroFit — root aggregate .env.example
# =============================================================================
# This file is a single-place reference for EVERY environment variable used
# anywhere in the monorepo. Each artifact also keeps its own .env.example
# next to its package.json — those are the authoritative sources for that
# artifact and the ones each service actually loads at runtime:
#
#   artifacts/api-server/.env.example  (loaded by the Express API)
#   artifacts/admin/.env.example       (loaded by the Next.js admin)
#   artifacts/mobile/.env.example      (loaded by the Expo mobile app)
#
# To bootstrap a fresh checkout:
#
#   cp .env.example .env
#   cp artifacts/api-server/.env.example artifacts/api-server/.env
#   cp artifacts/admin/.env.example      artifacts/admin/.env
#   cp artifacts/mobile/.env.example     artifacts/mobile/.env
#
# `scripts/dev.sh` does this for you on first run.
# =============================================================================


# ── Postgres (used by docker-compose and the api-server) ─────────────────────
# Provider sign-up: https://neon.tech (managed) or run the bundled docker
# `postgres` service for local dev.
POSTGRES_USER=neurofit
POSTGRES_PASSWORD=neurofit
POSTGRES_DB=neurofit
DATABASE_URL=postgresql://neurofit:neurofit@localhost:5432/neurofit


# ── API server (artifacts/api-server) ────────────────────────────────────────
PORT=8080
NODE_ENV=development
LOG_LEVEL=info
CORS_ORIGIN=http://localhost:3000

# JWT — generate with: openssl rand -base64 48
JWT_ACCESS_SECRET=replace_me_with_long_random_string
JWT_REFRESH_SECRET=replace_me_with_another_long_random_string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# Apple Sign-In — https://developer.apple.com/sign-in-with-apple/
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# Google Sign-In — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Cron + support tokens — generate with: openssl rand -hex 32
CRON_SECRET=replace_me
SUPPORT_TOKEN=replace_me

# Stripe — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Apple in-app purchase shared secret — App Store Connect → My Apps → App
# Information → App-Specific Shared Secret.
APPLE_SHARED_SECRET=

# Google Play in-app billing — service account JSON (path or base64).
# https://play.google.com/console → API access → Service accounts.
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON=
GOOGLE_PLAY_PACKAGE_NAME=

SUBSCRIPTION_TRIAL_DAYS=7
SUBSCRIPTION_REMINDER_HOURS=48

# Email transport — Resend wins if both are set. https://resend.com/api-keys
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
RESEND_API_KEY=

# Expo Push — https://expo.dev → Account → Access tokens
EXPO_ACCESS_TOKEN=

FROM_EMAIL=hello@neurofit.example


# ── Admin console (artifacts/admin) ──────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8080
# Public origin the admin redirects back to after sign-out — set to the
# externally reachable URL of the admin (no trailing slash). Defaults to
# http://localhost when unset, which only works in dev.
NEXT_PUBLIC_BASE_URL=http://localhost:3100
ADMIN_API_INTERNAL_URL=http://localhost:8080
COOKIE_SECURE=false


# ── Mobile app (artifacts/mobile) ────────────────────────────────────────────
EXPO_PUBLIC_API_URL=http://localhost:8080

# Optional — only set when serving the mobile web build behind a path
# prefix (e.g. /mobile under a shared reverse proxy). Default is "/".
BASE_PATH=/

# Optional — explicit public host for the mobile web build / Expo dev
# proxy. The mobile build script (`scripts/build.js`) prefers this over
# any platform-specific fallbacks.
EXPO_PUBLIC_DOMAIN=

# AdMob rewarded ad unit IDs — leave blank in dev (test units are used).
# https://apps.admob.com → Apps → Ad units
EXPO_PUBLIC_ADMOB_ANDROID_REWARDED_UNIT=
EXPO_PUBLIC_ADMOB_IOS_REWARDED_UNIT=
